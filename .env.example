# ─── Copy to .env and edit. Never commit .env. ───────────────────

# Database ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/jugabet.db

# Site / parser ─────────────────────────────────────────────────
SITE_BASE=https://jugabet.cl
FORCED_TIMEZONE=America/Santiago
PARSER_REFRESH_SECONDS=120
PARSER_TIMEOUT_MS=30000
PARSER_JS_SETTLE_MS=1200

# Drift canary: detects when jugabet changes their embedded JSON shape
# (page still advertises events but the extractor returns 0). Runs each
# campaign-monitor cycle; surfaced in /health and via Telegram alerts.
PARSER_CANARY_ENABLED=true
PARSER_CANARY_URL=https://jugabet.cl/football/all/1

# Match lifecycle ───────────────────────────────────────────────
MATCH_DEACTIVATE_AFTER_HOURS=12

# Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Security ──────────────────────────────────────────────────────
# Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Cookies ───────────────────────────────────────────────────────
# Set to true on production (HTTPS only)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Login rate limit ──────────────────────────────────────────────
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15

# Production hardening
APP_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8000
ALLOWED_HOSTS=127.0.0.1,localhost,::1
PARSER_ENABLED=true
PARSER_MAX_CONCURRENCY=2
PUBLIC_CACHE_SECONDS=30
PUBLIC_CACHE_MAX_ENTRIES=256
ALLOWED_LOGO_HOSTS=jugabet.cl,www.jugabet.cl

# Telegram alerts / campaign monitor ────────────────────────────
# Create a bot with @BotFather to get the token; get your numeric chat id
# from @userinfobot. Leave blank to disable Telegram alerts entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CAMPAIGN_MONITOR_ENABLED=true
CAMPAIGN_MONITOR_INTERVAL_SECONDS=300
CAMPAIGN_STALE_MINUTES=20

# Figma read-only File-content PAT for /admin/figma (GOW image export)
FIGMA_TOKEN=
