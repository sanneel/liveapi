# Template for /var/www/jugabet-staging/.env
# Copy to .env on the VPS and fill in real values. Never commit the real .env.

APP_ENV=staging

# ── Database ──────────────────────────────────────────────────────────
# MUST be an ABSOLUTE path. A relative path like ./data/jugabet.db would
# resolve relative to the CWD at process start (set by systemd
# WorkingDirectory), which is fine for THIS process but breaks Alembic CLI
# runs from your home directory.
DATABASE_URL=sqlite:////var/www/jugabet-staging/data/jugabet.db

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 48
# `validate_production()` only enforces this in app_env=production, but you
# still want a unique value in staging so cookies don't cross instances.
JWT_SECRET_KEY=REPLACE_WITH_48_HEX_CHARS_FROM_OPENSSL

# ── Cookies / routing ────────────────────────────────────────────────
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
ALLOWED_HOSTS=staging.yourdomain.tld,127.0.0.1
PUBLIC_BASE_URL=https://staging.yourdomain.tld

# ── Parser ───────────────────────────────────────────────────────────
PARSER_ENABLED=true
PARSER_REFRESH_SECONDS=120

# ── Cache ────────────────────────────────────────────────────────────
PUBLIC_CACHE_SECONDS=30
PUBLIC_CACHE_MAX_ENTRIES=256

# ── Logo allow-list (image URLs the renderer is allowed to fetch) ────
ALLOWED_LOGO_HOSTS=jugabet.cl,www.jugabet.cl

# ── Rate limiting on /admin/login ────────────────────────────────────
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15
